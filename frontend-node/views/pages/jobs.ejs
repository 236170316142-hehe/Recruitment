<div class="jobs-container">
  <section class="card create-job-section">
    <h2>📋 Create New Job</h2>
    <form method="POST" action="/jobs/create" enctype="multipart/form-data" class="job-form">
      <div class="form-group">
        <label>Job Description (Paste or Upload)</label>
        <textarea name="text" rows="6" placeholder="Paste job description here..." required></textarea>
      </div>
      <div class="form-group">
        <label>Or upload JD file (.pdf/.docx/.txt)</label>
        <input type="file" name="file" accept=".pdf,.docx,.txt,.md" />
      </div>
      <button type="submit" class="btn btn-primary">Create Job</button>
    </form>
  </section>

  <section class="card jobs-list-section">
    <h2>📂 Active Jobs</h2>
    <% if (jobs && jobs.length > 0) { %>
      <div class="jobs-grid">
        <% jobs.forEach(job => { %>
          <div class="job-card">
            <h3><%= job.title %></h3>
            <p class="meta">ID: <code><%= job.job_id.substring(0, 12) %>...</code></p>
            <p class="meta">Skills: <%= job.required_skills.join(", ") || "N/A" %></p>
            <p class="meta">Min Exp: <%= job.min_experience_years %> years</p>
            <p class="meta">Created: <%= new Date(job.created_at).toLocaleString() %></p>
            <div class="job-card-actions">
              <a href="/resumes?jobId=<%= job.job_id %>" class="btn btn-secondary">Upload Resumes</a>
              <a href="/dashboard?jobId=<%= job.job_id %>" class="btn btn-accent">View Matches</a>
              <button onclick="deleteJob('<%= job.job_id %>')" class="btn btn-danger">Delete</button>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="empty-state">No active jobs. Create one to get started.</p>
    <% } %>
  </section>
</div>

<script>
async function deleteJob(jobId) {
  if (!confirm("Are you sure you want to delete this job? This will also delete all resumes and matches associated with it.")) {
    return;
  }

  try {
    const response = await fetch(`/api/jobs/${jobId}`, {
      method: 'DELETE',
    });

    if (response.ok) {
      alert("Job deleted successfully");
      location.reload();
    } else {
      const data = await response.json();
      alert("Error: " + (data.error || "Failed to delete job"));
    }
  } catch (err) {
    alert("Network error: " + err.message);
  }
}
</script>
