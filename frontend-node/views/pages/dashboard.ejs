<div class="dashboard-container">
  <section class="card filters-section">
    <h2>🔍 Filters & Actions</h2>
    <div class="filters-grid">
      <div class="filter-group">
        <label>Job</label>
        <select id="jobFilterSelect" onchange="handleJobFilterChange(this.value)">
          <option value="">-- Select Job --</option>
          <% if (availableJobs && availableJobs.length > 0) { %>
            <% availableJobs.forEach(job => { %>
              <option value="<%= job.job_id %>" <%= selectedJobId === job.job_id ? 'selected' : '' %>>
                <%= (job.title || 'Untitled Job').substring(0, 50) %><%= (job.title && job.title.length > 50) ? '...' : '' %>
              </option>
            <% }) %>
          <% } %>
        </select>
      </div>

      <% if (selectedJobId) { %>
        <div class="filter-group">
          <label>Confidence</label>
          <select id="confidenceFilter" onchange="applyFilters()">
            <option value="">All</option>
            <option value="HIGH">HIGH</option>
            <option value="MEDIUM">MEDIUM</option>
            <option value="LOW">LOW</option>
          </select>
        </div>

        <div class="filter-group">
          <label>Source</label>
          <select id="sourceFilter" onchange="applyFilters()">
            <option value="">All</option>
            <option value="manual">Manual</option>
            <option value="gmail">Gmail</option>
          </select>
        </div>

        <div class="filter-group">
          <label>Search</label>
          <input type="text" id="searchInput" placeholder="Candidate name or email..." onkeyup="applyFilters()" />
        </div>

        <button class="btn btn-primary" onclick="generateRankings()">
          ⚡ Match Candidates
        </button>
      <% } %>
    </div>
  </section>

  <% if (selectedJobId && dashboard) { %>
    <section class="card rankings-section">
      <h2>📊 Matched Candidates (High Level > <%= dashboard.threshold || 70 %>%)</h2>
      <p class="meta">Total: <%= dashboard.total_candidates %> matches | Generated: <%= new Date(dashboard.generated_at).toLocaleString() %></p>
      
      <% if (dashboard.candidates.length === 0) { %>
        <div class="info-message">
          No candidates currently match the <strong>HIGH (70%+)</strong> threshold. 
          Use the filters above to see all candidates or try re-matching.
        </div>
      <% } %>

      <div class="table-wrap">
        <table class="rankings-table">
          <thead>
            <tr>
              <th>Match</th>
              <th>Name</th>
              <th>Source</th>
              <th>Score</th>
              <th>Confidence</th>
              <th>Strengths</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="candidateTableBody">
            <% dashboard.candidates.forEach((candidate, index) => { %>
              <tr class="candidate-row" data-resume-id="<%= candidate.resume_id %>">
                <td class="rank-cell"><strong>#<%= index + 1 %></strong></td>
                <td class="name-cell">
                  <strong><%= candidate.name %></strong>
                  <br/>
                  <small><%= candidate.email || "no-email" %></small>
                </td>
                <td class="source-cell">
                  <% if (candidate.source === 'gmail') { %>
                    <span class="badge badge-gmail">📧 Gmail</span>
                  <% } else { %>
                    <span class="badge badge-manual">📂 Manual</span>
                  <% } %>
                </td>
                <td class="score-cell"><%= Math.round(candidate.score) %>/100</td>
                <td class="confidence-cell">
                  <span class="confidence-pill confidence-<%= candidate.confidence.toLowerCase() %>">
                    <%= candidate.confidence %>
                  </span>
                </td>
                <td class="strengths-cell">
                  <% if (candidate.strengths && candidate.strengths.length > 0) { %>
                    <div class="strength-tags">
                      <% candidate.strengths.slice(0, 2).forEach(s => { %>
                        <span class="tag-strength"><%= typeof s === 'string' ? s.substring(0, 20) : '' %></span>
                      <% }) %>
                      <% if (candidate.strengths.length > 2) { %>
                        <span class="tag-more">+<%= candidate.strengths.length - 2 %></span>
                      <% } %>
                    </div>
                  <% } else { %>
                    <span class="muted">--</span>
                  <% } %>
                </td>
                <td class="actions-cell">
                  <a href="/candidate/<%= candidate.resume_id %>" class="btn btn-sm btn-secondary">View</a>
                  <button onclick="previewResume('<%= candidate.resume_id %>', '<%= candidate.name %>', '<%= candidate.resume_url %>', '<%= candidate.filename %>')" class="btn btn-sm btn-accent">Resume</button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  <% } else if (selectedJobId) { %>
    <section class="card empty-state-section">
      <p class="empty-state">No matches yet. Upload resumes and click "Match Candidates" to find the best talent.</p>
    </section>
  <% } else { %>
    <section class="card empty-state-section">
      <p class="empty-state">Select a job to find matched candidates.</p>
    </section>
  <% } %>
</div>

<!-- Resume Preview Modal -->
<div id="resumeModal" class="resume-modal">
  <div class="resume-modal-content">
    <div class="resume-modal-header">
      <h3 id="modalCandidateName">Resume Preview</h3>
      <span class="close-modal" onclick="closeResumeModal()">&times;</span>
    </div>
    <div id="modalResumeBody" class="resume-modal-body">
      <!-- Preview will be injected here -->
    </div>
    <div class="resume-modal-footer">
      <a id="downloadResumeBtn" href="#" target="_blank" class="btn btn-primary btn-sm">📥 Download Original</a>
    </div>
  </div>
</div>

<!-- Dependencies for Word Preview -->
<script src="https://unpkg.com/jszip/dist/jszip.min.js"></script>
<script src="https://unpkg.com/docx-preview/dist/docx-preview.js"></script>

<script>
function handleJobFilterChange(jobId) {
  if (jobId) {
    window.location.href = '/dashboard?jobId=' + jobId + '&confidence=HIGH';
  }
}

function applyFilters() {
  const jobId = document.getElementById('jobFilterSelect').value;
  if (!jobId) return;

  const confidence = document.getElementById('confidenceFilter')?.value || '';
  const source = document.getElementById('sourceFilter')?.value || '';
  const search = document.getElementById('searchInput')?.value || '';

  let url = `/dashboard?jobId=${jobId}`;
  if (confidence) url += `&confidence=${confidence}`;
  if (source) url += `&source=${source}`;
  if (search) url += `&search=${search}`;

  window.location.href = url;
}

function generateRankings() {
  const jobId = document.getElementById('jobFilterSelect').value;
  if (!jobId) {
    alert('Please select a job');
    return;
  }

  fetch(`/api/judge-batch/${jobId}`, { method: 'POST' })
    .then(res => res.json())
    .then(data => {
      alert('Candidate matching complete!');
      window.location.href = `/dashboard?jobId=${jobId}&confidence=HIGH`;
    })
    .catch(err => {
      alert('Error matching candidates: ' + err.message);
    });
}

function previewResume(resumeId, name, url, filename = '') {
  const modal = document.getElementById('resumeModal');
  const body = document.getElementById('modalResumeBody');
  const nameEl = document.getElementById('modalCandidateName');
  const downloadBtn = document.getElementById('downloadResumeBtn');
  
  nameEl.innerText = `Resume: ${name}`;
  downloadBtn.href = url;
  body.innerHTML = '<div class="loading-spinner">⌛ Loading resume...</div>';
  modal.style.display = 'block';
  document.body.style.overflow = 'hidden'; // Prevent scroll

  const ext = (filename || '').toLowerCase().split('.').pop();

  if (ext === 'pdf') {
    body.innerHTML = `<iframe src="${url}" class="resume-iframe"></iframe>`;
  } else if (ext === 'docx') {
    body.innerHTML = '<div id="modal-docx-container"></div>';
    const container = document.getElementById('modal-docx-container');
    
    fetch(url)
      .then(response => response.arrayBuffer())
      .then(arrayBuffer => {
        docx.renderAsync(arrayBuffer, container)
          .catch(err => {
            console.error("docx error:", err);
            body.innerHTML = '<p class="error-message">Error rendering Word document. Please download to view.</p>';
          });
      })
      .catch(err => {
        body.innerHTML = '<p class="error-message">Failed to fetch resume file.</p>';
      });
  } else {
    body.innerHTML = `
      <div class="viewer-fallback">
        <p>Direct preview not available for this file type (${ext.toUpperCase()}).</p>
        <a href="${url}" target="_blank" class="btn btn-primary">📥 Download to View</a>
      </div>`;
  }
}

function closeResumeModal() {
  const modal = document.getElementById('resumeModal');
  modal.style.display = 'none';
  document.body.style.overflow = 'auto'; // Restore scroll
  document.getElementById('modalResumeBody').innerHTML = '';
}

// Close on click outside
window.onclick = function(event) {
  const modal = document.getElementById('resumeModal');
  if (event.target == modal) {
    closeResumeModal();
  }
}
</script>

<style>
.resume-modal {
  display: none;
  position: fixed;
  z-index: 2000;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0,0,0,0.6);
  backdrop-filter: blur(4px);
}

.resume-modal-content {
  background-color: #fefefe;
  margin: 2% auto;
  padding: 0;
  border-radius: 12px;
  width: 85%;
  max-width: 1000px;
  height: 90vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 10px 25px rgba(0,0,0,0.3);
  overflow: hidden;
}

.resume-modal-header {
  padding: 16px 24px;
  background: var(--bg-white);
  border-bottom: 1px solid var(--border-color);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.resume-modal-header h3 {
  margin: 0;
  color: var(--text-dark);
}

.close-modal {
  color: var(--text-light);
  font-size: 28px;
  font-weight: bold;
  cursor: pointer;
}

.close-modal:hover {
  color: var(--error-color);
}

.resume-modal-body {
  flex: 1;
  background: #f1f5f9;
  position: relative;
  overflow: hidden;
}

.resume-modal-body .resume-iframe {
  width: 100%;
  height: 100%;
  border: none;
}

#modal-docx-container {
  height: 100%;
  overflow-y: auto;
  background: white;
  padding: 40px;
}

.resume-modal-footer {
  padding: 12px 24px;
  background: var(--bg-white);
  border-top: 1px solid var(--border-color);
  display: flex;
  justify-content: flex-end;
}

.loading-spinner {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  font-size: 1.2rem;
  color: var(--text-light);
}

/* Override docx-preview for modal */
.resume-modal-body .docx-wrapper {
  background: transparent !important;
  padding: 0 !important;
}
.resume-modal-body .docx {
  box-shadow: 0 0 10px rgba(0,0,0,0.1) !important;
}
</style>
